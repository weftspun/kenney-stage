                point3f[] points = [(0.5, 0.5, 0.13999996), (0.5, -0.5, 0.14000005), (-0.19999997, 0.5, 0.13999996), (-0.20256652, 0.46084207, 0.13999997), (-0.21022224, 0.4223543, 0.13999997), (-0.5, -0.5, 0.14000005), (-0.2228361, 0.38519496, 0.13999997), (-0.24019237, 0.35, 0.13999997), (-0.26199397, 0.31737158, 0.13999997), (-0.28786796, 0.28786796, 0.13999999), (-0.31737158, 0.26199397, 0.13999999), (-0.35, 0.24019238, 0.13999999), (-0.38519496, 0.22283612, 0.13999999), (-0.42235422, 0.21022226, 0.13999999), (-0.46084207, 0.20256653, 0.13999999), (-0.5, 0.2, 0.13999999)]
                texCoord2f[] primvars:st = [(-19.68504, -19.68504), (-19.68504, 19.68504), (7.8740153, -19.68504), (7.97506, -18.14339), (8.276466, -16.628122), (19.68504, 19.68504), (8.773076, -15.165156), (9.456392, -13.779528), (10.314724, -12.494944), (11.3333845, -11.3333845), (12.494944, -10.314724), (13.779528, -9.456392), (15.165156, -8.773076), (16.62812, -8.276466), (18.14339, -7.9750605), (19.68504, -7.874016)] (

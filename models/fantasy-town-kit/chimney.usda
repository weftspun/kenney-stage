            point3f[] points = [(0.42499998, -0.13000001, 9.814728e-9), (0.42499998, 0.13000001, -9.814728e-9), (0.2530917, -0.13000001, 9.814728e-9), (0.2530917, 0.13000001, -9.814728e-9), (0.42499998, 0.13000008, 1), (0.42499998, -0.12999994, 1), (0.2530917, 0.13000008, 1), (0.2530917, -0.12999994, 1), (0.26309168, 0.17000003, 0.375), (0.42499998, 0.17000003, 0.375), (0.26309168, 0.17000005, 0.625), (0.42499998, 0.17000005, 0.625), (0.42499998, -0.16999996, 0.625), (0.42499998, -0.16999997, 0.375), (0.21309169, 0.12000003, 0.375), (0.21309169, 0.12000004, 0.625), (0.21309169, -0.11999997, 0.375), (0.21309169, -0.11999995, 0.625), (0.26309168, -0.16999997, 0.375), (0.26309168, -0.16999996, 0.625)]
            texCoord2f[] primvars:st = [(0.96875, 0.074999996), (0.96875, 0.074999996), (0.96875, 0.074999996), (0.96875, 0.074999996), (0.96875, 0.175), (0.96875, 0.175), (0.96875, 0.175), (0.96875, 0.175), (0.21875, 0.325), (0.21875, 0.325), (0.21875, 0.425), (0.21875, 0.425), (0.21875, 0.425), (0.21875, 0.325), (0.21875, 0.325), (0.21875, 0.425), (0.21875, 0.325), (0.21875, 0.425), (0.21875, 0.325), (0.21875, 0.425)] (

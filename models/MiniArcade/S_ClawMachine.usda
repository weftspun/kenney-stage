                    interpolation = "faceVarying"
                )
                point3f[] points = [(-0.19999999, 0.2, 0.24999999), (-0.19999999, 0.20000003, 0.54999995), (-0.19999999, -0.19999997, 0.25000003), (-0.19999999, -0.19999994, 0.5500001), (0.19999999, -0.19999997, 0.25000003), (0.19999999, -0.19999994, 0.5500001), (0.19999999, 0.20000003, 0.54999995), (0.19999999, 0.2, 0.24999999)]

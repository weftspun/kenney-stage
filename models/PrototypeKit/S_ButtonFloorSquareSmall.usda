                point3f[] points = [(0.19999999, 0.17928933, 0.09999998), (0.16, 0.14343147, 0.14999999), (0.17928931, 0.2, 0.09999998), (0.14343145, 0.16000001, 0.14999999), (-0.14343145, -0.15999998, 0.15000002), (-0.17928931, -0.19999997, 0.10000001), (-0.16, -0.14343144, 0.15000002), (-0.19999999, -0.1792893, 0.10000001), (0.17928931, -0.19999997, 0.10000001), (0.14343145, -0.15999998, 0.15000002), (0.19999999, -0.1792893, 0.10000001), (0.16, -0.14343144, 0.15000002), (-0.17928931, 0.2, 0.09999998), (-0.14343145, 0.16000001, 0.14999999), (-0.19999999, 0.17928933, 0.09999998), (-0.16, 0.14343147, 0.14999999)]
                texCoord2f[] primvars:st = [(0.59375, 0.4083333), (0.59375, 0.475), (0.59375, 0.4083333), (0.59375, 0.475), (0.59375, 0.475), (0.59375, 0.4083333), (0.59375, 0.475), (0.59375, 0.4083333), (0.59375, 0.4083333), (0.59375, 0.475), (0.59375, 0.4083333), (0.59375, 0.475), (0.59375, 0.4083333), (0.59375, 0.475), (0.59375, 0.4083333), (0.59375, 0.475)] (

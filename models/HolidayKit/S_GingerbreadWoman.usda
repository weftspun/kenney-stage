                point3f[] points = [(0.0851714, 0.054831002, 0.06069755), (0.112228334, 0.028994646, 0.060697556), (0.050192446, 0.049853373, 0.15029895), (0.084192194, 0.0067066513, 0.15029895), (-0.11222836, 0.028994646, 0.060697556), (-0.085171394, 0.054831002, 0.06069755), (-0.050192453, 0.049853373, 0.15029895), (-0.084192194, 0.0067066513, 0.15029895), (-0.085171394, -0.06888499, 0.060697563), (-0.11222836, -0.043239024, 0.06069756), (-0.084192194, -0.024578577, 0.15029897), (-0.050192453, -0.06740735, 0.15029897), (0.112228334, -0.043239024, 0.06069756), (0.0851714, -0.06888499, 0.060697563), (0.084192194, -0.024578577, 0.15029897), (0.050192446, -0.06740735, 0.15029897)]
                texCoord2f[] primvars:st = [(0.21875, 0.311), (0.21875, 0.311), (0.21875, 0.475), (0.21875, 0.475), (0.21875, 0.311), (0.21875, 0.311), (0.21875, 0.475), (0.21875, 0.475), (0.21875, 0.311), (0.21875, 0.311), (0.21875, 0.475), (0.21875, 0.475), (0.21875, 0.311), (0.21875, 0.311), (0.21875, 0.475), (0.21875, 0.475)] (

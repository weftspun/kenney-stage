#usda 1.0
(
    defaultPrim = "root"
    doc = "Blender v5.1.2"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "root" (
    customData = {
        dictionary Blender = {
            bool generated = 1
        }
    }
)
{
    float3 xformOp:rotateXYZ = (-90, -0, 0)
    uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]

    def Xform "tree_pine_large"
    {
        custom string userProperties:blender:object_name = "tree-pine-large"

        def Mesh "Scene" (
            active = true
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            uniform bool doubleSided = 1
            float3[] extent = [(-0.65, -0.65, -4.9073634e-8), (0.65, 0.6500001, 1.6999999)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 4, 3, 2, 5, 3, 4, 6, 7, 2, 8, 2, 7, 9, 8, 7, 3, 9, 7]
            rel material:binding = </root/_materials/treeB>
            normal3f[] normals = [(-1, 1.4993544e-14, -7.6654566e-22), (-1, 1.4993544e-14, -1.0027383e-21), (-1, 1.4993544e-14, -1.060714e-21), (-1, 1.4993545e-14, -1.1498186e-21), (-1, 1.4993544e-14, -1.060714e-21), (-1, 1.4993544e-14, -1.0027383e-21), (-1, 1.4993544e-14, -1.1498186e-21), (-1, 1.4993545e-14, -1.1498186e-21), (-1, 1.4993544e-14, -1.0027383e-21), (-1, 1.4993547e-14, -1.1498186e-21), (-1, 1.4993545e-14, -1.1498186e-21), (-1, 1.4993544e-14, -1.1498186e-21), (0, 1, -7.54979e-8), (0, 1, -7.549791e-8), (0, 1, -7.54979e-8), (0, 1, -7.54979e-8), (0, 1, -7.54979e-8), (0, 1, -7.549791e-8), (0, 1, -7.54979e-8), (0, 1, -7.54979e-8), (0, 1, -7.549791e-8), (-2.291383e-9, 0.00004777114, -1), (0, 1, -7.54979e-8), (0, 1, -7.549791e-8)] (
                interpolation = "faceVarying"
            )
            point3f[] points = [(1.01969985e-14, 0.65, -4.9073634e-8), (1.01969985e-14, 0.6500001, 1.6999999), (4.5119465e-16, 3.609557e-16, -2.7251396e-23), (4.5119465e-16, 1.2834643e-7, 1.6999999), (-9.294609e-15, -0.65, 4.9073634e-8), (-9.294609e-15, -0.64999986, 1.6999999), (-0.65, 3.609557e-16, -2.7251396e-23), (-0.65, 1.2834643e-7, 1.6999999), (0.65, 3.609557e-16, -2.7251396e-23), (0.65, 1.2834643e-7, 1.6999999)]
            texCoord2f[] primvars:st = [(-0.88423526, 0), (-0.8842349, 0.9840004), (-0.50799984, 0), (-0.5079995, 0.9840004), (-0.13176438, 0), (-0.13176407, 0.9840004), (-0.13176438, -0), (-0.13176407, 0.9840004), (-0.88423526, -0), (-0.8842349, 0.9840004)] (
                interpolation = "faceVarying"
            )
            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 4, 3, 2, 5, 3, 4, 6, 7, 2, 8, 2, 7, 9, 8, 7, 3, 9, 7]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"
        }
    }

    def Scope "_materials"
    {
        def Material "treeB"
        {
            token outputs:surface.connect = </root/_materials/treeB/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "treeB"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/treeB/Image_Texture.outputs:rgb>
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:ior = 1.5
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.5
                float inputs:specular = 0.5
                token outputs:surface
            }

            def Shader "Image_Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/T_TreeB_D.png@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/treeB/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "uvmap"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}


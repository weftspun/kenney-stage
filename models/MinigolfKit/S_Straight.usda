            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 4, 5, 0, 2, 0, 5, 1, 3, 6, 7, 6, 3, 4, 8, 5, 9, 5, 8, 10, 12, 8, 9, 8, 12, 14, 15, 6, 6, 15, 1, 0, 1, 15, 15, 10, 0, 4, 0, 10, 8, 4, 10, 14, 17, 15, 18, 15, 17, 9, 12, 5, 5, 12, 2, 3, 2, 12, 12, 18, 3, 7, 3, 18, 17, 7, 18, 14, 6, 17, 7, 17, 6, 11, 16, 13, 19, 13, 16]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"

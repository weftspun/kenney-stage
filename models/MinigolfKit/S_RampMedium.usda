            texCoord2f[] primvars:st = [(0.71875, 0.025), (0.71875, 0.098944925), (0.71875, 0.15105508), (0.71875, 0.225), (0.71875, 0.098944925), (0.71875, 0.225), (0.71875, 0.05693076), (0.15625, 0.375), (0.71875, 0.025), (0.71875, 0.05693076), (0.15625, 0.375), (0.71875, 0.098944925), (0.71875, 0.098944925), (0.71875, 0.225), (0.71875, 0.225), (0.71875, 0.18298584), (0.71875, 0.15105508), (0.71875, 0.18298584), (0.15625, 0.375), (0.15625, 0.375)] (
                interpolation = "faceVarying"

            int[] primvars:st:indices = [0, 4, 2, 6, 2, 4, 8, 12, 10, 14, 10, 12, 16, 14, 12, 18, 16, 12, 4, 18, 12, 21, 4, 12, 4, 23, 18, 0, 23, 4, 23, 26, 18, 28, 26, 23, 26, 30, 18, 32, 18, 30, 34, 38, 36, 40, 36, 38, 43, 40, 38, 45, 43, 38, 47, 45, 38, 50, 47, 38, 47, 52, 45, 54, 52, 47, 52, 56, 45, 58, 56, 52, 56, 60, 45, 62, 45, 60, 43, 45, 64, 66, 64, 45, 68, 70, 54, 52, 54, 70, 72, 74, 16, 14, 16, 74, 63, 61, 11, 9, 11, 61, 22, 13, 59, 57, 59, 13, 76, 78, 31, 33, 31, 78, 79, 48, 81, 51, 81, 48, 46, 63, 67, 75, 67, 63, 15, 75, 63, 11, 15, 63, 5, 22, 7, 71, 7, 22, 53, 71, 22, 59, 53, 22, 82, 39, 84, 35, 84, 39, 86, 37, 87, 41, 87, 37, 82, 81, 39, 51, 39, 81, 9, 61, 13, 57, 13, 61, 27, 89, 31, 76, 31, 89, 35, 37, 84, 86, 84, 37, 24, 91, 29, 93, 29, 91, 27, 29, 89, 93, 89, 29, 33, 78, 19, 94, 19, 78, 96, 98, 97, 99, 97, 98, 100, 102, 101, 103, 101, 102, 102, 104, 103, 105, 103, 104, 85, 83, 106, 107, 106, 83, 85, 106, 108, 99, 108, 106, 97, 99, 106, 106, 100, 97, 104, 100, 106, 102, 100, 104, 100, 77, 97, 109, 97, 77, 104, 106, 105, 107, 105, 106, 99, 98, 108, 110, 108, 98, 100, 101, 77, 90, 77, 101, 110, 83, 108, 85, 108, 83, 90, 101, 111, 96, 111, 101, 98, 96, 101, 101, 107, 98, 103, 107, 101, 105, 107, 103, 107, 83, 98, 110, 98, 83, 109, 111, 97, 96, 97, 111, 90, 111, 77, 109, 77, 111, 95, 73, 20, 17, 20, 73, 25, 1, 92, 3, 92, 1, 42, 44, 88, 65, 88, 44, 80, 69, 49, 55, 49, 69]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"

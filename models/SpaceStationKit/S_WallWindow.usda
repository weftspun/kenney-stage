            int[] primvars:st:indices = [0, 4, 2, 6, 2, 4, 8, 6, 4, 10, 8, 4, 12, 10, 4, 10, 14, 8, 14, 16, 8, 18, 16, 14, 16, 20, 8, 22, 8, 20, 24, 28, 26, 30, 26, 28, 32, 30, 28, 34, 32, 28, 36, 34, 28, 34, 38, 32, 38, 40, 32, 42, 40, 38, 40, 44, 32, 46, 32, 44, 8, 48, 6, 50, 6, 48, 34, 52, 38, 54, 38, 52, 14, 10, 56, 58, 56, 10, 30, 32, 60, 62, 60, 32, 17, 29, 21, 25, 21, 29, 25, 27, 21, 23, 21, 27, 17, 19, 29, 37, 29, 19, 15, 57, 19, 37, 19, 57, 53, 37, 57, 35, 37, 53, 23, 27, 9, 49, 9, 27, 61, 49, 27, 31, 61, 27, 13, 5, 43, 41, 43, 5, 47, 45, 3, 1, 3, 45, 33, 47, 63, 51, 63, 47, 7, 51, 47, 3, 7, 47, 11, 13, 59, 55, 59, 13, 39, 55, 13, 43, 39, 13, 1, 45, 5, 41, 5, 45, 64, 66, 65, 67, 65, 66, 67, 66, 68, 69, 68, 66, 70, 68, 71, 69, 71, 68, 70, 71, 65, 64, 65, 71, 72, 74, 73, 75, 73, 74, 72, 73, 76, 77, 76, 73, 78, 80, 79, 81, 79, 80, 79, 81, 74, 75, 74, 81, 82, 84, 83, 80, 83, 84, 71, 80, 84, 77, 71, 84, 71, 69, 80, 64, 71, 77, 81, 80, 69, 66, 64, 77, 66, 81, 69, 77, 81, 66, 73, 81, 77, 75, 81, 73, 85, 78, 86, 87, 86, 78, 68, 87, 78, 79, 68, 78, 68, 70, 87, 67, 68, 79, 76, 87, 70, 65, 67, 79, 65, 76, 70, 79, 76, 65, 74, 76, 79, 72, 76, 74, 76, 77, 87, 84, 87, 77, 87, 84, 86, 82, 86, 84, 82, 83, 86, 85, 86, 83, 85, 83, 78, 80, 78, 83]
            uniform token subdivisionScheme = "none"

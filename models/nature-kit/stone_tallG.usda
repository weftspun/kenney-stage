            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 4, 6, 5, 7, 5, 6, 8, 10, 9, 11, 9, 10, 12, 11, 10, 13, 15, 14, 16, 14, 15, 17, 14, 16, 18, 20, 19, 21, 19, 20, 22, 21, 20, 23, 25, 24, 26, 24, 25, 27, 26, 25, 28, 30, 29, 31, 29, 30, 32, 34, 33, 35, 33, 34, 36, 33, 35, 37, 39, 38, 40, 38, 39, 41, 43, 42, 44, 42, 43, 45, 44, 43, 46, 48, 47, 49, 47, 48, 50, 52, 51, 53, 51, 52, 54, 53, 52, 55, 53, 54, 56, 58, 57, 59, 61, 60, 62, 60, 61, 63, 62, 61, 64, 66, 65, 67, 65, 66, 68, 67, 66, 69, 71, 70, 72, 70, 71, 73, 75, 74, 76, 78, 77, 79, 77, 78, 80, 82, 81, 83, 81, 82, 84, 86, 85, 87, 85, 86, 88, 87, 86, 89, 91, 90, 92, 90, 91, 93, 92, 91, 94, 96, 95, 97, 95, 96, 98, 97, 96, 99, 98, 96, 100, 98, 99, 101, 103, 102, 104, 106, 105, 107, 109, 108, 110, 112, 111, 113, 115, 114]
            uniform token subdivisionScheme = "none"

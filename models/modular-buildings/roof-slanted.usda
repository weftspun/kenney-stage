            point3f[] points = [(0.5, -0.582137, -0.05703953), (0.5, -0.5, 3.7748947e-8), (-0.5, -0.582137, -0.05703953), (-0.5, -0.5, 3.7748947e-8), (0.5, 0.50000006, 0.7249999), (0.5, 0.50000006, 0.62499994), (0.5, 0.3686832, 0.72499996), (0.5, 0.40000004, 0.62499994), (0.5, -0.6391766, 0.025097463), (-0.5, 0.50000006, 0.7249999), (-0.5, 0.3686832, 0.72499996), (-0.5, -0.6391766, 0.025097463), (-0.5, 0.50000006, 0.62499994), (-0.5, 0.40000004, 0.62499994), (-0.5, 0.5, -3.7748947e-8), (0.5, 0.5, -3.7748947e-8), (-0.5, -0.5, 3.7748947e-8), (0.5, -0.5, 3.7748947e-8)]
            texCoord2f[] primvars:st = [(0.09375, 0.025), (0.09375, 0.025), (0.09375, 0.025), (0.09375, 0.025), (0.09375, 0.225), (0.96875, 0.225), (0.09375, 0.1974138), (0.96875, 0.1974138), (0.09375, 0.225), (0.09375, 0.1974138), (0.96875, 0.1974138), (0.09375, 0.031923424), (0.09375, 0.225), (0.96875, 0.225), (0.09375, 0.225), (0.09375, 0.031923424), (0.09375, 0.1974138), (0.96875, 0.1974138), (0.09375, 0.1974138), (0.96875, 0.1974138), (0.96875, 0.025), (0.96875, 0.025), (0.96875, 0.025), (0.96875, 0.025)] (

            )
            point3f[] points = [(-0.07076412, 3.365418e-8, 0.44576412), (-0.07076412, 4.094622e-9, 0.054235872), (-0.07076412, -0.024999965, 0.44576412), (-0.07076412, -0.024999995, 0.054235876), (0.125, 0.025000036, 0.5), (0.125, 0.024999999, -1.8874475e-9), (0.125, -0.024999961, 0.5), (0.125, -0.024999999, 1.8874475e-9), (0.07076412, -0.024999995, 0.054235876), (0.07076412, 4.0947636e-9, 0.054235872), (0.07076412, 3.3654324e-8, 0.44576412), (0.07076412, -0.024999965, 0.44576412), (-0.125, 0.024999999, -1.8874475e-9), (-0.125, 0.025000036, 0.5), (-0.125, -0.024999999, 1.8874475e-9), (-0.125, -0.024999961, 0.5)]
            texCoord2f[] primvars:st = [(0.46875, 0.20330565), (0.71875, 0.45330566), (0.46875, 0.04669435), (0.71875, 0.29669434), (0.46875, 0.20330565), (0.46875, 0.04669435), (0.46875, 0.225), (0.46875, 0.025), (0.46875, 0.225), (0.46875, 0.025), (0.46875, 0.04669435), (0.46875, 0.04669435), (0.71875, 0.29669434), (0.46875, 0.20330565), (0.71875, 0.45330566), (0.46875, 0.20330565), (0.46875, 0.025), (0.46875, 0.225), (0.46875, 0.025), (0.46875, 0.225)] (

            int[] primvars:st:indices = [0, 4, 2, 5, 2, 4, 7, 11, 9, 13, 9, 11, 15, 19, 17, 21, 17, 19, 23, 27, 25, 28, 25, 27, 30, 32, 31, 33, 31, 32, 34, 36, 35, 37, 35, 36, 38, 40, 39, 41, 39, 40, 42, 41, 40, 41, 43, 39, 44, 42, 40, 45, 39, 43, 46, 42, 44, 36, 45, 43, 34, 46, 44, 34, 45, 36, 44, 45, 34, 47, 45, 44, 48, 46, 35, 34, 35, 46, 49, 51, 50, 52, 50, 51, 32, 40, 33, 38, 33, 40, 46, 48, 42, 53, 42, 48, 54, 55, 30, 32, 30, 55, 31, 33, 49, 51, 49, 33, 55, 56, 44, 47, 44, 56, 53, 57, 42, 41, 42, 57, 54, 58, 55, 56, 55, 58, 58, 50, 56, 52, 56, 50, 52, 51, 45, 39, 45, 51, 41, 57, 43, 59, 43, 57, 36, 43, 37, 59, 37, 43, 57, 53, 59, 48, 59, 53, 37, 59, 48, 35, 37, 48, 55, 44, 32, 40, 32, 44, 56, 52, 47, 45, 47, 52, 33, 38, 51, 39, 51, 38, 58, 60, 50, 58, 54, 60, 60, 62, 50, 60, 54, 64, 62, 66, 50, 64, 54, 68, 50, 66, 49, 54, 30, 68, 66, 70, 49, 68, 30, 70, 31, 49, 70, 31, 70, 30, 71, 67, 69, 8, 69, 67, 12, 8, 67, 63, 12, 67, 14, 12, 63, 8, 1, 69, 8, 10, 1, 1, 3, 69, 72, 1, 10, 14, 72, 10, 65, 69, 3, 6, 72, 14, 6, 65, 3, 61, 65, 63, 6, 14, 16, 16, 14, 63, 16, 24, 6, 24, 65, 6, 20, 16, 63, 16, 18, 24, 22, 20, 63, 26, 65, 24, 73, 24, 18, 22, 73, 18, 29, 65, 26, 63, 65, 29, 29, 22, 63, 29, 73, 22]
            uniform token subdivisionScheme = "none"

#usda 1.0
(
    defaultPrim = "root"
    doc = "Blender v5.1.2"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "root" (
    customData = {
        dictionary Blender = {
            bool generated = 1
        }
    }
)
{
    float3 xformOp:rotateXYZ = (-90, -0, 0)
    uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]

    def Xform "door_wide_open"
    {
        custom string userProperties:blender:object_name = "door-wide-open"

        def Mesh "Scene" (
            active = true
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            uniform bool doubleSided = 1
            float3[] extent = [(-0.9, -0.6999999, 0.8198058), (0.9, -0.3999999, 1.5999999)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 4, 6, 5, 7, 4, 5, 5, 6, 8, 5, 9, 7, 10, 8, 6, 7, 9, 11, 9, 10, 11, 6, 11, 10, 3, 2, 12, 13, 12, 2, 5, 14, 9, 15, 9, 14, 11, 6, 16, 17, 16, 6]
            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(0, 0.8773112, 0.47992182), (0, 0.8773112, 0.47992182), (0, 0.8773112, 0.47992182), (0, 0.87731135, 0.47992158), (0, 0.87731135, 0.47992158), (0, 0.87731135, 0.47992158), (1.3408551e-8, 1, 0), (8.804754e-9, 1, -4.5908425e-7), (6.333016e-9, 1, 0), (-1.3408563e-8, 1, 0), (1.3408551e-8, 1, 0), (6.333016e-9, 1, 0), (6.333016e-9, 1, 0), (8.804754e-9, 1, -4.5908425e-7), (1.0646677e-8, 1, -5.375539e-8), (6.333016e-9, 1, 0), (-6.3329986e-9, 1, 0), (-1.3408563e-8, 1, 0), (-1.06466524e-8, 1, -4.134736e-8), (1.0646677e-8, 1, -5.375539e-8), (8.804754e-9, 1, -4.5908425e-7), (-1.3408563e-8, 1, 0), (-6.3329986e-9, 1, 0), (-8.804639e-9, 1, 0), (-6.3329986e-9, 1, 0), (-1.06466524e-8, 1, -4.134736e-8), (-8.804639e-9, 1, 0), (8.804754e-9, 1, -4.5908425e-7), (-8.804639e-9, 1, 0), (-1.06466524e-8, 1, -4.134736e-8), (0, 0.5203503, 0.85395294), (0, 0.5203501, 0.853953), (0, 0.5203503, 0.85395294), (0, 0.5203501, 0.853953), (0, 0.5203503, 0.85395294), (0, 0.5203501, 0.853953), (6.333016e-9, 1, 0), (0, 1, 0), (-6.3329986e-9, 1, 0), (0, 1, 0), (-6.3329986e-9, 1, 0), (0, 1, 0), (-8.804639e-9, 1, 0), (8.804754e-9, 1, -4.5908425e-7), (0, 1, 0), (0, 1, 0), (0, 1, 0), (8.804754e-9, 1, -4.5908425e-7)] (
                interpolation = "faceVarying"
            )
            point3f[] points = [(-0.9, -0.3999999, 1.2833759), (0.9, -0.3999999, 1.2833759), (-0.9, -0.5098075, 1.4841075), (0.9, -0.5098075, 1.4841075), (-0.117887065, -0.39999992, 0.98301166), (-0.9, -0.3999999, 1.0515908), (-0.117887065, -0.39999992, 0.888385), (0.117887065, -0.39999992, 0.98301166), (-0.9, -0.39999992, 0.8198058), (0.9, -0.3999999, 1.0515908), (0.9, -0.39999992, 0.8198058), (0.117887065, -0.39999992, 0.888385), (0.9, -0.6999999, 1.5999999), (-0.9, -0.6999999, 1.5999999), (-0.9, -0.3999999, 1.2833756), (0.9, -0.3999999, 1.2833756), (0.117887065, -0.39999992, 0.9830117), (-0.117887065, -0.39999992, 0.9830117)]
            texCoord2f[] primvars:st = [(0.84375, 0.19794917), (0.84375, 0.19794917), (0.84375, 0.225), (0.84375, 0.088094), (0.84375, 0.225), (0.84375, 0.088094), (0.84375, 0.15747175), (0.84375, 0.16671355), (0.84375, 0.025), (0.84375, 0.14471975), (0.34375, 0.025), (0.84375, 0.15747175), (0.84375, 0.13547795), (0.84375, 0.16671355), (0.84375, 0.025), (0.84375, 0.13547795), (0.84375, 0.14471975), (0.34375, 0.025), (0.84375, 0.105), (0.84375, 0.105), (0.84375, 0.05881198), (0.84375, 0.05881198), (0.34375, 0.025), (0.34375, 0.025)] (
                interpolation = "faceVarying"
            )
            int[] primvars:st:indices = [0, 2, 1, 4, 1, 2, 6, 9, 7, 11, 6, 7, 7, 9, 12, 7, 13, 11, 15, 12, 9, 11, 13, 16, 13, 15, 16, 9, 16, 15, 5, 3, 18, 19, 18, 3, 8, 20, 14, 21, 14, 20, 17, 10, 22, 23, 22, 10]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"
        }
    }

    def Scope "_materials"
    {
        def Material "colormap"
        {
            token outputs:surface.connect = </root/_materials/colormap/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "colormap"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/colormap/Image_Texture.outputs:rgb>
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:ior = 1.5
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.5
                float inputs:specular = 0.5
                token outputs:surface
            }

            def Shader "Image_Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/T_Colormap_D.png@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/colormap/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "uvmap"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}


            point3f[] points = [(0.2385, -0.078999996, 5.9643335e-9), (0.2385, 0.078999996, -5.9643335e-9), (-0.23850001, -0.078999996, 5.9643335e-9), (-0.23850001, 0.078999996, -5.9643335e-9), (-0.23850001, 0.079, 0.09099998), (-0.23850001, -0.07899999, 0.091), (-0.23349997, 0.07400001, 0.09599999), (-0.23349997, -0.07399999, 0.09600001), (0.2385, -0.07899999, 0.091), (0.2335, -0.07399999, 0.09600001), (0.2385, 0.079, 0.09099998), (0.2335, 0.07400001, 0.09599999)]
            texCoord2f[] primvars:st = [(0.59375, 0.025), (0.59375, 0.025), (0.59375, 0.025), (0.59375, 0.025), (0.59375, 0.21458332), (0.59375, 0.21458332), (0.59375, 0.225), (0.59375, 0.225), (0.59375, 0.21458332), (0.59375, 0.225), (0.59375, 0.21458332), (0.59375, 0.225)] (

            float3[] extent = [(-0.23850001, -0.078999996, -5.9643335e-9), (0.2385, 0.079, 0.09600001)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]

            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(-0.70931995, 3.716488e-8, 0.70488673), (-0.7093199, -6.016752e-9, 0.7048867), (-0.70932025, 2.4732793e-7, 0.7048864), (-0.7093204, 3.4340442e-7, 0.7048862), (-0.70932025, 2.4732793e-7, 0.7048864), (-0.7093199, -6.016752e-9, 0.7048867), (-0.70931953, -4.3426874e-7, 0.7048871), (-0.7093204, 3.4340442e-7, 0.7048862), (-0.7093199, -6.016752e-9, 0.7048867), (-0.70931834, -0.000001761613, 0.7048883), (-0.70931953, -4.3426874e-7, 0.7048871), (-0.7093199, -6.016752e-9, 0.7048867), (-0.99999994, -6.140049e-8, 0), (-1, -2.6341633e-9, 0), (-1, -5.8766336e-8, 0), (-0.99999994, 0, 0), (-1, -5.8766336e-8, 0), (-1, -2.6341633e-9, 0), (0, 6.564389e-8, 1), (0, 6.564388e-8, 1), (0, 6.564388e-8, 1), (0, 6.564388e-8, 1), (0, 6.564388e-8, 1), (0, 6.564388e-8, 1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -1, 0), (1.5792315e-9, -0.9576337, 0.2879893), (3.1351785e-8, -1, 0), (3.9952425e-8, -1, 0), (3.1351785e-8, -1, 0), (1.5792315e-9, -0.9576337, 0.2879893), (0, -0.9759044, 0.21819864), (3.9952425e-8, -1, 0), (1.5792315e-9, -0.9576337, 0.2879893), (1.5792315e-9, -0.9576337, 0.2879893), (0, -0.70710915, 0.70710444), (0, -0.9759044, 0.21819864), (0, -0.70710826, 0.70710534), (0, -0.9759044, 0.21819864), (0, -0.70710915, 0.70710444), (1, 0, 0), (1, 0, 0), (0.95763266, 1.520068e-8, 0.28799233), (0.9576356, 2.8291666e-8, 0.2879826), (0.95763266, 1.520068e-8, 0.28799233), (1, 0, 0), (0.9576356, 2.8291666e-8, 0.2879826), (0.70710826, 6.900404e-8, 0.70710534), (0.95763266, 1.520068e-8, 0.28799233), (0.707108, 3.6263437e-8, 0.70710564), (0.95763266, 1.520068e-8, 0.28799233), (0.70710826, 6.900404e-8, 0.70710534), (0, 1, 0), (-1.88937e-9, 1, -8.667046e-8), (-7.713046e-9, 1, 0), (-3.9691024e-9, 0.95763355, 0.28798974), (-7.713046e-9, 1, 0), (-1.88937e-9, 1, -8.667046e-8), (0, 0.97590446, 0.21819843), (-3.9691024e-9, 0.95763355, 0.28798974), (-1.88937e-9, 1, -8.667046e-8), 
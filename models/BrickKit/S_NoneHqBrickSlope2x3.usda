            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 4, 3, 2, 5, 4, 2, 6, 7, 0, 2, 0, 7, 8, 3, 9, 4, 9, 3, 10, 7, 11, 6, 11, 7, 10, 12, 7, 2, 7, 12, 5, 2, 12, 12, 9, 5, 4, 5, 9, 10, 11, 12, 13, 12, 11, 13, 8, 12, 9, 12, 8, 6, 0, 11, 13, 11, 0, 1, 13, 0, 1, 3, 13, 8, 13, 3]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"

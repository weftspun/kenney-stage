            texCoord2f[] primvars:st = [(0.21875, 0.025), (0.21875, 0.025), (0.21875, 0.025), (0.21875, 0.025), (0.21875, 0.025), (0.21875, 0.025), (0.21875, 0.025), (0.21875, 0.025), (0.21875, 0.225), (0.21875, 0.225), (0.21875, 0.225), (0.21875, 0.225), (0.21875, 0.225), (0.21875, 0.225), (0.21875, 0.225), (0.21875, 0.225)] (

            texCoord2f[] primvars:st = [(0.71875, 0.025), (0.71875, 0.070357315), (0.71875, 0.17964268), (0.71875, 0.225), (0.71875, 0.070357315), (0.71875, 0.225), (0.71875, 0.044586115), (0.15625, 0.375), (0.71875, 0.025), (0.71875, 0.044586115), (0.15625, 0.375), (0.71875, 0.070357315), (0.71875, 0.070357315), (0.71875, 0.225), (0.71875, 0.225), (0.71875, 0.19922881), (0.15625, 0.375), (0.71875, 0.17964268), (0.71875, 0.19922881), (0.15625, 0.375)] (

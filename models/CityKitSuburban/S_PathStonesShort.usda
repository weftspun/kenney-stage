            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(-0.40824744, 0.40824932, 0.8164965), (-0.30019188, 0.30019298, 0.90541095), (0.40824854, 0.40824804, 0.8164966), (0.30019426, 0.30019292, 0.9054102), (0.40824854, 0.40824804, 0.8164966), (-0.30019188, 0.30019298, 0.90541095), (0.30019426, 0.30019292, 0.9054102), (-0.30019188, 0.30019298, 0.90541095), (0.30019188, -0.30019277, 0.905411), (-0.30019426, -0.3001928, 0.90541023), (0.30019188, -0.30019277, 0.905411), (-0.30019188, 0.30019298, 0.90541095), (0.40824854, 0.40824804, 0.8164966), (0.30019426, 0.30019292, 0.9054102), (0.40824735, -0.40824914, 0.8164966), (0.30019188, -0.30019277, 0.905411), (0.40824735, -0.40824914, 0.8164966), (0.30019426, 0.30019292, 0.9054102), (-0.30019188, 0.30019298, 0.90541095), (-0.40824744, 0.40824932, 0.8164965), (-0.30019426, -0.3001928, 0.90541023), (-0.40824848, -0.40824795, 0.8164967), (-0.30019426, -0.3001928, 0.90541023), (-0.40824744, 0.40824932, 0.8164965), (0.40824735, -0.40824914, 0.8164966), (0.30019188, -0.30019277, 0.905411), (-0.40824848, -0.40824795, 0.8164967), (-0.30019426, -0.3001928, 0.90541023), (-0.40824848, -0.40824795, 0.8164967), (0.30019188, -0.30019277, 0.905411), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (0, -7.54979e-8, -1), (-0.40824735, 0.40824926, 0.8164966), (-0.30019188, 0.30019292, 0.905411), (0.4082485, 0.40824807, 0.8164966), (0.30019426, 0.3001929, 0.9054102), (0.4082485, 0.40824807, 0.8164966), (-0.30019188, 0.30019292, 0.905411), (0.30019426, 0.3001929, 0.9054102), (-0.30019188, 0.30019292, 0.905411), (0.3001918, -0.30019286, 0.905411), (-0.3001943, -0.30019286, 0.90541023), (0.3001918, -0.30019286, 0.905411), (-0.30019188, 0.30019292, 0.905411), (0.4082485, 0.40824807, 0.8164966), (0.30019426, 0.3001929, 0.9054102), (0.40824735, -0.40824917, 0.8164966), (0.3001918, -0.30019286, 0.905411), (0.40824735, -0.40824917, 0.8164966), (0.30019426, 0.3001929, 0.9054102), (-0.30019188, 0.30019292, 0.90541
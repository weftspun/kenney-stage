#usda 1.0
(
    defaultPrim = "root"
    doc = "Blender v5.1.2"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "root" (
    customData = {
        dictionary Blender = {
            bool generated = 1
        }
    }
)
{
    float3 xformOp:rotateXYZ = (-90, -0, 0)
    uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]

    def Xform "path_long"
    {
        custom string userProperties:blender:object_name = "path-long"

        def Mesh "Scene" (
            active = true
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            uniform bool doubleSided = 1
            float3[] extent = [(-0.099999994, -0.19999999, -1.509958e-8), (0.099999994, 0.19999999, 0.010000015)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 1, 3, 4, 5, 4, 3, 4, 5, 6, 7, 6, 5, 0, 6, 2, 7, 2, 6, 1, 4, 0, 6, 0, 4, 5, 3, 7, 2, 7, 3]
            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(0, -7.549791e-8, -1), (0, -7.549791e-8, -1), (0, -7.549791e-8, -1), (0, -7.549791e-8, -1), (0, -7.549791e-8, -1), (0, -7.549791e-8, -1), (0, 1, 0.000003725291), (0, 1, -0.0000036698486), (0, 1, 0.0000035368312), (0, 1, -0.000005321844), (0, 1, 0.0000035368312), (0, 1, -0.0000036698486), (0, 7.4505806e-8, 1), (0, 7.4505806e-8, 1), (0, 7.4505806e-8, 1), (0, 7.4505806e-8, 1), (0, 7.4505806e-8, 1), (0, 7.4505806e-8, 1), (0, -1, 0.000003725291), (0, -1, 0.0000035368312), (0, -1, -0.0000036698486), (0, -1, -0.000005321844), (0, -1, -0.0000036698486), (0, -1, 0.0000035368312), (0.31622785, 8.283098e-8, 0.9486833), (0.31622782, 8.190674e-8, 0.94868326), (0.31622782, 6.5348324e-8, 0.94868326), (0.31622785, 6.44241e-8, 0.9486833), (0.31622782, 6.5348324e-8, 0.94868326), (0.31622782, 8.190674e-8, 0.94868326), (-0.31622785, 7.362754e-8, 0.9486833), (-0.31622782, 7.362753e-8, 0.94868326), (-0.31622782, 7.362753e-8, 0.94868326), (-0.31622785, 7.362754e-8, 0.9486833), (-0.31622782, 7.362753e-8, 0.94868326), (-0.31622782, 7.362753e-8, 0.94868326)] (
                interpolation = "faceVarying"
            )
            point3f[] points = [(0.099999994, -0.19999999, 1.509958e-8), (0.099999994, 0.19999999, -1.509958e-8), (-0.099999994, -0.19999999, 1.509958e-8), (-0.099999994, 0.19999999, -1.509958e-8), (0.07, 0.19999999, 0.009999985), (-0.07, 0.19999999, 0.009999985), (0.07, -0.19999999, 0.010000015), (-0.07, -0.19999999, 0.010000015)]
            texCoord2f[] primvars:st = [(0.09375, 0.325), (0.59375, 0.325), (0.09375, 0.325), (0.59375, 0.325), (0.09375, 0.325), (0.59375, 0.325), (0.09375, 0.325), (0.59375, 0.325), (0.09375, 0.425), (0.59375, 0.425), (0.09375, 0.425), (0.59375, 0.425), (0.09375, 0.425), (0.59375, 0.425), (0.09375, 0.425), (0.59375, 0.425)] (
                interpolation = "faceVarying"
            )
            int[] primvars:st:indices = [0, 4, 2, 6, 2, 4, 2, 6, 8, 10, 8, 6, 8, 10, 12, 14, 12, 10, 0, 12, 4, 14, 4, 12, 3, 9, 1, 13, 1, 9, 11, 7, 15, 5, 15, 7]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"
        }
    }

    def Scope "_materials"
    {
        def Material "colormap"
        {
            token outputs:surface.connect = </root/_materials/colormap/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "colormap"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/colormap/Image_Texture.outputs:rgb>
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:ior = 1.5
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.5
                float inputs:specular = 0.5
                token outputs:surface
            }

            def Shader "Image_Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/T_Colormap_D.png@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/colormap/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "uvmap"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}


#usda 1.0
(
    defaultPrim = "root"
    doc = "Blender v5.1.2"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "root" (
    customData = {
        dictionary Blender = {
            bool generated = 1
        }
    }
)
{
    float3 xformOp:rotateXYZ = (-90, -0, 0)
    uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]

    def Xform "none_hq_plate_2x4"
    {
        custom string userProperties:blender:object_name = "none-hq-plate-2x4"

        def Mesh "Scene" (
            active = true
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            uniform bool doubleSided = 1
            float3[] extent = [(-0.15900001, -0.078999996, -5.9643335e-9), (0.159, 0.078999996, 0.032)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 3, 2, 4, 5, 4, 2, 5, 6, 4, 7, 4, 6, 0, 8, 2, 5, 2, 8, 8, 9, 5, 6, 5, 9, 3, 4, 1, 10, 1, 4, 4, 7, 10, 11, 10, 7, 11, 7, 9, 6, 9, 7, 0, 1, 8, 10, 8, 1, 10, 11, 8, 9, 8, 11]
            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(0, -7.549789e-8, -1), (0, -7.549789e-8, -1), (0, -7.549789e-8, -1), (0, -7.5497894e-8, -1), (0, -7.549789e-8, -1), (0, -7.549789e-8, -1), (-0.99999994, 0, 0), (-1, 0, 0), (-0.9576343, 2.0510278e-9, 0.28798693), (-0.95763516, 4.243751e-8, 0.2879844), (-0.9576343, 2.0510278e-9, 0.28798693), (-1, 0, 0), (-0.95763516, 4.243751e-8, 0.2879844), (-0.7071051, 1.01999255e-7, 0.7071085), (-0.9576343, 2.0510278e-9, 0.28798693), (-0.70710504, 0, 0.70710856), (-0.9576343, 2.0510278e-9, 0.28798693), (-0.7071051, 1.01999255e-7, 0.7071085), (0, -1, 0), (0, -0.9576363, 0.2879804), (0, -1, 0), (0, -0.95763546, 0.2879832), (0, -1, 0), (0, -0.9576363, 0.2879804), (0, -0.9576363, 0.2879804), (0, -0.70710695, 0.70710653), (0, -0.95763546, 0.2879832), (0, -0.70710635, 0.7071072), (0, -0.95763546, 0.2879832), (0, -0.70710695, 0.70710653), (0, 1, 0), (0, 0.95763636, 0.2879802), (0, 1, 0), (0, 0.9576354, 0.28798327), (0, 1, 0), (0, 0.95763636, 0.2879802), (0, 0.95763636, 0.2879802), (0, 0.7071065, 0.70710707), (0, 0.9576354, 0.28798327), (0, 0.7071075, 0.70710605), (0, 0.9576354, 0.28798327), (0, 0.7071065, 0.70710707), (0, 5.0341757e-8, 1), (0, 5.0341757e-8, 1), (0, 5.0341757e-8, 1), (0, 5.0341757e-8, 1), (0, 5.0341757e-8, 1), (0, 5.0341757e-8, 1), (0.99999994, 0, 0), (1, 0, 0), (0.95763475, 2.0510333e-9, 0.28798565), (0.95763546, 4.2437566e-8, 0.2879831), (0.95763475, 2.0510333e-9, 0.28798565), (1, 0, 0), (0.95763546, 4.2437566e-8, 0.2879831), (0.7071072, 1.01999554e-7, 0.7071064), (0.95763475, 2.0510333e-9, 0.28798565), (0.7071072, 0, 0.7071065), (0.95763475, 2.0510333e-9, 0.28798565), (0.7071072, 1.01999554e-7, 0.7071064)] (
                interpolation = "faceVarying"
            )
            point3f[] points = [(0.159, -0.078999996, 5.9643335e-9), (0.159, 0.078999996, -5.9643335e-9), (-0.15900001, -0.078999996, 5.9643335e-9), (-0.15900001, 0.078999996, -5.9643335e-9), (-0.15900001, 0.078999996, 0.026999991), (-0.15900001, -0.078999996, 0.027000003), (-0.15399998, -0.074, 0.032), (-0.15399998, 0.074, 0.031999994), (0.159, -0.078999996, 0.027000003), (0.154, -0.074, 0.032), (0.159, 0.078999996, 0.026999991), (0.154, 0.074, 0.031999994)]
            texCoord2f[] primvars:st = [(0.59375, 0.025), (0.59375, 0.025), (0.59375, 0.025), (0.59375, 0.025), (0.59375, 0.19375), (0.59375, 0.19375), (0.59375, 0.225), (0.59375, 0.225), (0.59375, 0.19375), (0.59375, 0.225), (0.59375, 0.19375), (0.59375, 0.225)] (
                interpolation = "faceVarying"
            )
            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 3, 2, 4, 5, 4, 2, 5, 6, 4, 7, 4, 6, 0, 8, 2, 5, 2, 8, 8, 9, 5, 6, 5, 9, 3, 4, 1, 10, 1, 4, 4, 7, 10, 11, 10, 7, 11, 7, 9, 6, 9, 7, 0, 1, 8, 10, 8, 1, 10, 11, 8, 9, 8, 11]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"

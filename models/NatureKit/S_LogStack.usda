            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [160, 161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183]
                rel material:binding = </root/_materials/woodInner>
            }
        }
    }

    def Scope "_materials"
    {
        def Material "woodBark"
        {
            token outputs:surface.connect = </root/_materials/woodBark/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "woodBark"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor = (0.8862745, 0.5137255, 0.3411765)
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:ior = 1.5
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.5527864
                float inputs:specular = 1

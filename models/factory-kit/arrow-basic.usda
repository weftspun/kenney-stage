            point3f[] points = [(0.28284273, -0.28284273, 2.1354031e-8), (-1.29944044e-14, -1.29944044e-14, 9.810502e-22), (0.14142136, -0.42426407, 3.2031046e-8), (-0.28284273, -3.7539392e-14, 2.8341453e-21), (0.14142136, 0.42426407, -3.2031046e-8), (0.28284273, 0.28284273, -2.1354031e-8), (0.28284273, 0.28284276, 0.19999997), (-1.29944044e-14, 1.5099568e-8, 0.19999999), (0.14142136, 0.4242641, 0.19999996), (-0.28284273, 1.5099543e-8, 0.19999999), (0.14142136, -0.42426404, 0.20000002), (0.28284273, -0.2828427, 0.2)]
            texCoord2f[] primvars:st = [(0.84375, 0.025), (0.84375, 0.025), (0.84375, 0.025), (0.84375, 0.025), (0.84375, 0.025), (0.84375, 0.025), (0.84375, 0.225), (0.84375, 0.225), (0.84375, 0.225), (0.84375, 0.225), (0.84375, 0.225), (0.84375, 0.225)] (

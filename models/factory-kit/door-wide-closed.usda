                interpolation = "faceVarying"
            )
            point3f[] points = [(-0.9, -0.39999986, 1.39071), (0.9, -0.39999986, 1.39071), (-0.9, -0.39999986, 1.5999999), (0.9, -0.39999986, 1.5999999), (-0.9, -0.39999995, 0.46357), (0.9, -0.39999995, 0.46357), (-0.9, -0.39999992, 0.69535506), (0.9, -0.39999992, 0.69535506), (-0.9, -0.39999992, 0.92714), (0.9, -0.39999992, 0.92714), (-0.9, -0.3999999, 1.1589249), (0.9, -0.3999999, 1.1589249), (-0.117887065, -0.39999998, 0.16320589), (-0.9, -0.39999995, 0.23178501), (-0.117887065, -0.39999998, 0.06857917), (0.117887065, -0.39999998, 0.16320589), (-0.9, -0.39999998, 3.019916e-8), (0.9, -0.39999995, 0.23178501), (0.9, -0.39999998, 3.019916e-8), (0.117887065, -0.39999998, 0.06857917), (-0.9, -0.3999999, 1.1589249), (0.9, -0.3999999, 1.1589249), (-0.9, -0.39999986, 1.3907098), (0.9, -0.39999986, 1.3907098), (0.117887065, -0.39999998, 0.06857915), (0.117887065, -0.39999998, 0.16320589), (-0.117887065, -0.39999998, 0.06857915), (-0.117887065, -0.39999998, 0.16320589)]
            texCoord2f[] primvars:st = [(0.84375, 0.19883874), (0.84375, 0.19883874), (0.84375, 0.225), (0.84375, 0.225), (0.84375, 0.08294625), (0.84375, 0.041), (0.84375, 0.08294625), (0.84375, 0.041), (0.84375, 0.11191937), (0.84375, 0.057), (0.84375, 0.11191937), (0.84375, 0.057), (0.84375, 0.14089249), (0.84375, 0.073), (0.84375, 0.14089249), (0.84375, 0.073), (0.84375, 0.16986562), (0.84375, 0.16986562), (0.84375, 0.04540073), (0.84375, 0.053973123), (0.84375, 0.025), (0.84375, 0.03357239), (0.84375, 0.04540073), (0.84375, 0.025), (0.84375, 0.053973123), (0.84375, 0.025), (0.84375, 0.025), (0.84375, 0.03357239), (0.84375, 0.089), (0.84375, 0.089), (0.84375, 0.105), (0.84375, 0.105), (0.34375, 0.025), (0.34375, 0.025), (0.34375, 0.025), (0.34375, 0.025)] (

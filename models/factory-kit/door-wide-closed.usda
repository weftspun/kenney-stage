            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 4, 6, 5, 7, 5, 6, 8, 10, 9, 11, 9, 10, 12, 14, 13, 15, 12, 13, 13, 14, 16, 13, 17, 15, 18, 16, 14, 15, 17, 19, 17, 18, 19, 14, 19, 18, 20, 22, 21, 23, 21, 22, 13, 4, 17, 5, 17, 4, 6, 8, 7, 9, 7, 8, 24, 26, 25, 27, 25, 26]
            rel material:binding = </root/_materials/colormap>

            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 4, 6, 5, 7, 5, 6, 6, 8, 7, 9, 7, 8, 8, 1, 9, 3, 9, 1, 10, 2, 11, 0, 11, 2, 12, 10, 13, 11, 13, 10, 14, 12, 15, 13, 15, 12, 11, 0, 13, 15, 13, 0, 1, 15, 0, 4, 15, 1, 8, 4, 1, 6, 4, 8, 4, 5, 15, 14, 15, 5, 12, 14, 10, 2, 10, 14, 16, 2, 14, 5, 16, 14, 16, 18, 2, 20, 16, 5, 3, 2, 18, 22, 20, 5, 22, 3, 18, 5, 3, 22, 7, 3, 5, 9, 3, 7, 24, 27, 26, 29, 26, 27, 31, 26, 29, 33, 31, 29, 35, 39, 37, 40, 37, 39, 42, 40, 39, 44, 40, 42, 31, 42, 26, 39, 26, 42, 39, 35, 26, 24, 26, 35, 46, 48, 47, 49, 47, 48, 50, 52, 51, 53, 51, 52, 54, 53, 52, 46, 51, 48, 53, 48, 51, 48, 53, 49, 54, 49, 53, 55, 47, 52, 54, 52, 47, 49, 54, 47, 46, 47, 56, 55, 56, 47, 50, 51, 56, 46, 56, 51, 55, 52, 56, 50, 56, 52, 57, 59, 58, 60, 58, 59, 61, 59, 62, 57, 62, 59, 61, 62, 63, 64, 63, 62, 65, 64, 62, 64, 66, 63, 67, 63, 66, 62, 57, 65, 58, 65, 57, 67, 59, 63, 61, 63, 59, 67, 66, 59, 60, 59, 66, 64, 65, 66, 60, 66, 65, 58, 60, 65, 17, 68, 19, 69, 19, 68, 21, 23, 70, 71, 70, 23, 21, 70, 17, 68, 17, 70, 19, 69, 23, 71, 23, 69, 32, 34, 43, 45, 43, 34, 25, 36, 28, 38, 28, 36, 30, 28, 41, 38, 41, 28, 30, 41, 34, 45, 34, 41]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"

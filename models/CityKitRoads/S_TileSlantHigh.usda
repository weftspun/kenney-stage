#usda 1.0
(
    defaultPrim = "root"
    doc = "Blender v5.1.2"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "root" (
    customData = {
        dictionary Blender = {
            bool generated = 1
        }
    }
)
{
    float3 xformOp:rotateXYZ = (-90, -0, 0)
    uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]

    def Xform "tile_slantHigh"
    {
        custom string userProperties:blender:object_name = "tile-slantHigh"

        def Mesh "Scene" (
            active = true
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            uniform bool doubleSided = 1
            float3[] extent = [(-0.5, -0.5, -3.7748947e-8), (0.5, 0.50000006, 0.52000004)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 3, 2, 4, 5, 4, 2, 0, 6, 2, 5, 2, 6, 7, 4, 6, 5, 6, 4, 7, 6, 1, 0, 1, 6, 3, 4, 1, 7, 1, 4]
            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (-1, 9.313226e-8, 0), (-1, 1.1850589e-9, 0), (-1, 9.19472e-8, 0), (-1, 0, 0), (-1, 9.19472e-8, 0), (-1, 1.1850589e-9, 0), (0, -1, 0), (4.272204e-10, -1, 0), (2.0704473e-8, -1, 0), (2.9802294e-8, -1, 0), (2.0704473e-8, -1, 0), (4.272204e-10, -1, 0), (-0.44721353, 1.0662403e-7, 0.8944272), (-0.4472136, 8.521509e-8, 0.89442724), (-0.44721362, 8.804897e-8, 0.89442724), (-0.44721365, 6.664002e-8, 0.8944272), (-0.44721362, 8.804897e-8, 0.89442724), (-0.4472136, 8.521509e-8, 0.89442724), (1, 0, 0), (1, -7.963268e-8, 0), (1, -3.4991647e-8, 0), (1, -1.1462432e-7, 0), (1, -3.4991647e-8, 0), (1, -7.963268e-8, 0), (0, 1, 0), (-5.4497556e-10, 1, 0), (-2.2633204e-9, 1, 0), (-2.292491e-9, 1, 0), (-2.2633204e-9, 1, 0), (-5.4497556e-10, 1, 0)] (
                interpolation = "faceVarying"
            )
            point3f[] points = [(0.5, -0.5, 3.7748947e-8), (0.5, 0.5, -3.7748947e-8), (-0.5, -0.5, 3.7748947e-8), (-0.5, 0.5, -3.7748947e-8), (-0.5, 0.5, 0.019999962), (-0.5, -0.5, 0.020000037), (0.5, -0.49999997, 0.52000004), (0.5, 0.50000006, 0.5199999)]
            texCoord2f[] primvars:st = [(0.90625, 0.125), (0.90625, 0.125), (0.90625, 0.125), (0.90625, 0.125), (0.90625, 0.125), (0.90625, 0.125), (0.90625, 0.125), (0.90625, 0.125)] (
                interpolation = "faceVarying"
            )
            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 3, 2, 4, 5, 4, 2, 0, 6, 2, 5, 2, 6, 7, 4, 6, 5, 6, 4, 7, 6, 1, 0, 1, 6, 3, 4, 1, 7, 1, 4]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"
        }
    }

    def Scope "_materials"
    {
        def Material "colormap"
        {
            token outputs:surface.connect = </root/_materials/colormap/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "colormap"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/colormap/Image_Texture.outputs:rgb>
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:ior = 1.5
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.5
                float inputs:specular = 0.5
                token outputs:surface
            }

            def Shader "Image_Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/T_Colormap_D.png@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/colormap/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "uvmap"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}


            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 4, 6, 5, 7, 5, 6, 4, 5, 0, 2, 0, 5, 8, 10, 9, 11, 9, 10, 9, 12, 8, 13, 8, 12, 13, 14, 8, 10, 8, 14, 11, 10, 15, 14, 15, 10, 13, 12, 14, 15, 14, 12, 9, 11, 12, 15, 12, 11, 3, 2, 7, 5, 7, 2, 1, 6, 0, 4, 0, 6, 6, 1, 7, 3, 7, 1]
            rel material:binding = </root/_materials/colormap>

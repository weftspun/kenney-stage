            point3f[] points = [(-0.099999994, 0.5, -3.7748947e-8), (0.099999994, 0.5, -3.7748947e-8), (-0.099999994, 0.50000006, 0.99999994), (0.099999994, 0.50000006, 0.99999994), (0.099999994, -0.5, 3.7748947e-8), (-0.099999994, -0.5, 3.7748947e-8), (0.099999994, -0.4999999, 1), (-0.099999994, -0.4999999, 1), (-0.099999994, -0.29999998, 0.20000002), (0.099999994, -0.29999998, 0.20000002), (-0.099999994, -0.29999995, 0.79999995), (0.099999994, -0.29999995, 0.79999995), (0.099999994, 0.30000007, 0.79999995), (-0.099999994, 0.30000007, 0.79999995), (0.099999994, 0.30000004, 0.19999996), (-0.099999994, 0.30000004, 0.19999996)]
            texCoord2f[] primvars:st = [(0.46875, 0.025), (0.46875, 0.025), (0.46875, 0.225), (0.46875, 0.225), (0.46875, 0.025), (0.46875, 0.025), (0.46875, 0.225), (0.46875, 0.225), (0.46875, 0.065), (0.46875, 0.065), (0.46875, 0.185), (0.46875, 0.185), (0.46875, 0.185), (0.46875, 0.185), (0.46875, 0.065), (0.46875, 0.065)] (

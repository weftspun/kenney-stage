            float3[] extent = [(-0.25, -0.5, -3.7748947e-8), (0.25, 0.50000006, 1)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 4, 1, 3, 5, 4, 3, 6, 4, 5, 7, 9, 8, 10, 8, 9, 11, 8, 10, 12, 11, 10, 13, 11, 12, 6, 12, 4, 10, 4, 12, 10, 9, 4, 1, 4, 9, 9, 7, 1, 0, 1, 7, 7, 8, 0, 2, 0, 8, 8, 11, 2, 3, 2, 11, 3, 11, 5, 13, 5, 11, 6, 5, 12, 13, 12, 5]
            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(0, -7.549789e-8, -1), (0, -7.549789e-8, -1), (0, -7.5497894e-8, -1), (0, -7.549789e-8, -1), (0, -7.5497894e-8, -1), (0, -7.549789e-8, -1), (0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (0, -7.549789e-8, -1), (0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (0, -7.549789e-8, -1), (0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (0, -7.5497894e-8, -1), (0, 0, 1), (0, 0, 1), (0, 5.5062394e-8, 1), (3.8543075e-7, 5.506027e-8, 1), (0, 5.5062394e-8, 1), (0, 0, 1), (5.505094e-8, 6.329299e-8, 1), (0, 5.5062394e-8, 1), (3.8543075e-7, 5.506027e-8, 1), (4.4049702e-7, 6.698157e-8, 1), (5.505094e-8, 6.329299e-8, 1), (3.8543075e-7, 5.506027e-8, 1), (0, 5.9604645e-8, 1), (5.505094e-8, 6.329299e-8, 1), (4.4049702e-7, 6.698157e-8, 1), (0.25881895, 0.9659258, -5.7573665e-8), (0.25881884, 0.9659259, -5.757367e-8), (0.49999997, 0.86602545, -5.960465e-8), (0.49999997, 0.8660254, -5.9604645e-8), (0.49999997, 0.86602545, -5.960465e-8), (0.25881884, 0.9659259, -5.757367e-8), (0.49999997, 0.8660254, -5.9604645e-8), (0.8660282, 0.49999517, -4.0977806e-8), (0.49999997, 0.86602545, -5.960465e-8), (0.86602265, 0.5000047, -4.0978573e-8), (0.49999997, 0.86602545, -5.960465e-8), (0.8660282, 0.49999517, -4.0977806e-8), (0.8660282, 0.49999517, -4.0977806e-8), (1, -0.0000055097044, -3.7249077e-9), (0.86602265, 0.5000047, -4.0978573e-8), (1, 0.000005509704, -6.010003e-10), (0.86602265, 0.5000047, -4.0978573e-8), (1, -0.0000055097044, -3.7249077e-9), (1, -0.0000055097044, -3.7249077e-9), (0.8660226, -0.5000048, 3.78539e-8), (1, 0.000005509704, -6.010003e-10), (0.8660282, -0.49999523, 5.3476512e-8), (1, 0.000005509704, -6.010003e-10), (0.8660226, -0.5000048, 3.78539e-8), (0.8660226, -0.5000048, 3.78539e-8), (0.4999999, -0.86602545, 6.6811275e-8), (0.8660282, -0.49999523, 5.3476512e-8), (0.49999997, -0.86602545, 1.0430814e-7), (0.8660282, -0.49999523, 5.3476512e-8), (0.4999999, -0.86602545, 6.6811275e-8), (0.49999997, -0.86602545, 1.0430814e-7), (0.4999999, -0.86602545, 
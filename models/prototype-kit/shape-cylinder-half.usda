                interpolation = "faceVarying"
            )
            point3f[] points = [(0.25, 0, 0), (0.1830127, 0.25, -1.8874474e-8), (0.1830127, -0.25, 1.8874474e-8), (0, -0.43301272, 3.269155e-8), (0, 0.43301272, -3.269155e-8), (-0.25, -0.5, 3.7748947e-8), (-0.25, 0.5, -3.7748947e-8), (0.25, 7.5497894e-8, 1), (0.1830127, -0.24999993, 1), (0.1830127, 0.2500001, 1), (0, 0.4330128, 0.99999994), (0, -0.43301263, 1), (-0.25, 0.50000006, 0.99999994), (-0.25, -0.4999999, 1)]
            texCoord2f[] primvars:st = [(0.59375, 0.025), (0.46875, 0.025), (0.59375, 0.025), (0.46875, 0.025), (0.59375, 0.025), (0.46875, 0.025), (0.59375, 0.025), (0.46875, 0.025), (0.59375, 0.025), (0.46875, 0.025), (0.59375, 0.025), (0.46875, 0.025), (0.59375, 0.025), (0.46875, 0.025), (0.46875, 0.225), (0.46875, 0.225), (0.46875, 0.225), (0.46875, 0.225), (0.46875, 0.225), (0.46875, 0.225), (0.46875, 0.225)] (
                interpolation = "faceVarying"

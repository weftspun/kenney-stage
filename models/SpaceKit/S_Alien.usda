                int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 4, 6, 5, 7, 5, 6, 8, 10, 9, 11, 9, 10, 12, 14, 13, 15, 13, 14, 16, 18, 17, 19, 17, 18, 20, 19, 18, 21, 20, 18, 20, 22, 19, 23, 25, 24, 24, 26, 23, 23, 26, 27, 28, 27, 26, 29, 26, 24, 30, 32, 31, 33, 31, 32, 34, 36, 35, 37, 35, 36, 38, 40, 39, 41, 39, 40, 42, 44, 43, 45, 43, 44, 46, 19, 47, 22, 47, 19, 48, 49, 23, 25, 23, 49, 50, 52, 51, 53, 51, 52]
                uniform token subdivisionScheme = "none"

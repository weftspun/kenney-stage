            texCoord2f[] primvars:st = [(0.84375, 0.08044554), (0.84375, 0.025), (0.84375, 0.08044554), (0.84375, 0.025), (0.84375, 0.025), (0.84375, 0.08044554), (0.84375, 0.025), (0.84375, 0.08044554), (0.84375, 0.114108905), (0.96875, 0.114108905), (0.84375, 0.114108905), (0.96875, 0.114108905), (0.84375, 0.114108905), (0.96875, 0.114108905), (0.84375, 0.114108905), (0.96875, 0.114108905), (0.96875, 0.225), (0.96875, 0.225), (0.96875, 0.225), (0.96875, 0.225)] (

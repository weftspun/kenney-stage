            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 4, 6, 5, 5, 6, 8, 2, 8, 6, 6, 9, 2, 3, 2, 9, 11, 3, 9, 12, 5, 13, 8, 13, 5, 14, 6, 16, 4, 16, 6, 11, 17, 3, 1, 3, 17, 8, 2, 13, 0, 13, 2, 17, 18, 1, 1, 18, 0, 13, 0, 18, 18, 14, 13, 12, 13, 14, 16, 12, 14, 17, 11, 18, 9, 18, 11, 5, 12, 4, 16, 4, 12, 7, 15, 10, 19, 10, 15]

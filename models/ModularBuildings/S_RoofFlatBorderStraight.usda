            int[] faceVertexIndices = [0, 2, 1, 3, 1, 2, 4, 6, 5, 5, 6, 7, 2, 7, 6, 6, 8, 2, 3, 2, 8, 9, 3, 8, 10, 5, 11, 7, 11, 5, 12, 6, 13, 4, 13, 6, 9, 14, 3, 1, 3, 14, 7, 2, 11, 0, 11, 2, 14, 15, 1, 1, 15, 0, 11, 0, 15, 15, 12, 11, 10, 11, 12, 13, 10, 12, 14, 9, 15, 8, 15, 9, 5, 10, 4, 13, 4, 10, 6, 12, 8, 15, 8, 12]
            rel material:binding = </root/_materials/colormap>

            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(0, -0.8213698, -0.57039595), (0.50449663, -0.50449616, -0.7006902), (0, -0.8213699, -0.570396), (0.50449777, -0.50449497, -0.7006902), (0, -0.8213699, -0.570396), (0.50449663, -0.50449616, -0.7006902), (0, 0.5703961, -0.8213698), (0, 0.57039577, -0.82136995), (0, 0.570396, -0.82136977), (0, 0.5703957, -0.82136995), (0, 0.570396, -0.82136977), (0, 0.57039577, -0.82136995), (0.31167322, -0.31167307, 0.89761883), (0.5703959, 7.478456e-8, 0.8213699), (0.23060195, -0.23060168, 0.94532835), (0.29885632, 4.3163203e-7, 0.9542981), (0.23060195, -0.23060168, 0.94532835), (0.5703959, 7.478456e-8, 0.8213699), (-0.5703958, -6.885063e-8, -0.82137), (-0.5703958, -6.9100146e-8, -0.82137), (-0.5703958, -7.414708e-8, -0.82136995), (-0.57039577, -7.450581e-8, -0.82136995), (-0.5703958, -7.414708e-8, -0.82136995), (-0.5703958, -6.9100146e-8, -0.82137), (0.31167322, -0.31167307, 0.89761883), (0.23060195, -0.23060168, 0.94532835), (0, -0.5703957, 0.82137007), (0, -0.29885608, 0.9542982), (0, -0.5703957, 0.82137007), (0.23060195, -0.23060168, 0.94532835), (0.82136977, 0, -0.57039607), (0.50449777, -0.50449497, -0.7006902), (0.82136977, -7.67359e-9, -0.57039607), (0.50449663, -0.50449616, -0.7006902), (0.82136977, -7.67359e-9, -0.57039607), (0.50449777, -0.50449497, -0.7006902), (0.29885632, 4.3163203e-7, 0.9542981), (0, 4.538994e-7, 1), (0.23060195, -0.23060168, 0.94532835), (0, -0.29885608, 0.9542982), (0.23060195, -0.23060168, 0.94532835), (0, 4.538994e-7, 1), (-1, -8.221331e-8, 0), (-1, -9.1814435e-8, 0), (-1, -4.9380297e-8, 0), (-1, 0, 0), (-1, -4.9380297e-8, 0), (-1, -9.1814435e-8, 0), (-1, -1.8626449e-7, 0), (-1, 0, 0), (-1, -9.1814435e-8, 0), (-1, -3.7252903e-7, 0), (-1, -1.8626449e-7, 0), (-1, -9.1814435e-8, 0), (0, 0.99999994, 0), (5.7708105e-10, 1, 0), (7.3979e-9, 1, 0), (5.5126077e-9, 1, 0), (7.3979e-9, 1, 0), (5.7708105e-10, 1, 0), (0, 0.99999994, 0), (5.5126077e-9, 1, 0), (5.7708105e-10, 1, 0), (7.3979e-9, 1, 0), (5.5126077e-9, 1, 0), (0, 1,
            rel material:binding = </root/_materials/colormap>
            normal3f[] normals = [(0.64946216, 9.0646026e-8, 0.7603939), (0.64946216, 9.0646026e-8, 0.7603939), (0.64946216, 9.0646026e-8, 0.7603939), (-2.3513051e-8, 0.64946216, 0.76039386), (-2.3513051e-8, 0.64946216, 0.76039386), (-2.3513051e-8, 0.64946216, 0.76039386), (-0.75596553, -5.3428398e-8, -0.6546115), (-0.75596553, -5.1171693e-8, -0.65461147), (-0.7559655, -5.3325067e-8, -0.65461147), (-0.75596553, -5.109622e-8, -0.65461147), (-0.7559655, -5.3325067e-8, -0.65461147), (-0.75596553, -5.1171693e-8, -0.65461147), (0, -0.6494621, 0.760394), (0, -0.6494621, 0.760394), (0, -0.64946216, 0.760394), (0, -0.6494621, 0.7603939), (0, -0.64946216, 0.760394), (0, -0.6494621, 0.760394), (0, -0.75596553, -0.6546114), (0, -0.7559656, -0.6546114), (0, -0.75596607, -0.6546109), (0, -0.755966, -0.6546108), (0, -0.75596607, -0.6546109), (0, -0.7559656, -0.6546114), (-0.6494619, 8.3063526e-8, 0.7603941), (-0.64946204, 8.082606e-8, 0.760394), (-0.64946204, 8.0694825e-8, 0.76039404), (-0.6494621, 7.9437775e-8, 0.760394), (-0.64946204, 8.0694825e-8, 0.76039404), (-0.64946204, 8.082606e-8, 0.760394), (-8.940696e-8, 0.99999994, 0), (-8.385163e-8, 1, -1.0951647e-7), (-8.562942e-8, 1, 0), (-8.270692e-8, 1, -8.357221e-8), (-8.562942e-8, 1, 0), (-8.385163e-8, 1, -1.0951647e-7), (-7.694222e-8, 0.99999994, -2.557918e-7), (-8.270692e-8, 1, -8.357221e-8), (-8.385163e-8, 1, -1.0951647e-7), (1, 0.0000013000816, 9.750612e-7), (1, -2.9102445e-8, 5.4682822e-8), (1, 5.7601477e-7, 4.7610828e-7), (1, -4.0428986e-8, 0), (1, 5.7601477e-7, 4.7610828e-7), (1, -2.9102445e-8, 5.4682822e-8), (1, 0, 0), (1, -4.0428986e-8, 0), (1, -2.9102445e-8, 5.4682822e-8), (0, -7.5497894e-8, -1), (1.5986625e-15, -7.54979e-8, -1), (1.5986624e-15, -7.5497894e-8, -1), (3.197325e-15, -7.54979e-8, -1), (1.5986624e-15, -7.5497894e-8, -1), (1.5986625e-15, -7.54979e-8, -1)] (

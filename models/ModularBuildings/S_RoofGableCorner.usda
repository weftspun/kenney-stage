            point3f[] points = [(0.4999999, 0.5, 0.09169365), (-8.811518e-9, 2.1232967e-8, 0.51875), (-1.6262646e-8, 0.50000006, 0.51874995), (0.5, 2.8684099e-8, 0.51875), (-0.5, 0.4999999, -3.7748944e-8), (-0.54564273, 0.4999999, 0.052709598), (-0.5, -0.5, 3.7748947e-8), (-0.54564273, -0.54564273, 0.052709676), (0.5, -0.54564273, 0.052709676), (0.5, -0.5, 3.7748947e-8), (0.5, 0.5, -3.7748947e-8)]
            texCoord2f[] primvars:st = [(0.09375, 0.060351778), (0.96875, 0.060351778), (0.09375, 0.225), (0.09375, 0.225), (0.96875, 0.225), (0.09375, 0.225), (0.96875, 0.225), (0.09375, 0.025), (0.96875, 0.025), (0.09375, 0.04532179), (0.96875, 0.04532179), (0.09375, 0.025), (0.96875, 0.025), (0.09375, 0.04532179), (0.09375, 0.04532179), (0.96875, 0.04532179), (0.09375, 0.025), (0.96875, 0.025), (0.96875, 0.025)] (

            int[] primvars:st:indices = [0, 2, 1, 3, 1, 2, 4, 3, 2, 5, 3, 4, 6, 3, 5, 7, 3, 6, 3, 7, 8, 9, 8, 7, 11, 9, 7, 13, 8, 9, 13, 15, 8, 15, 17, 8, 19, 8, 17, 20, 19, 17, 22, 24, 5, 6, 5, 24, 2, 26, 4, 28, 4, 26, 30, 19, 31, 20, 31, 19, 24, 11, 6, 7, 6, 11, 0, 33, 2, 26, 2, 33, 35, 39, 37, 40, 37, 39, 4, 28, 5, 22, 5, 28, 35, 41, 39, 43, 39, 41, 40, 30, 37, 31, 37, 30, 44, 46, 41, 43, 41, 46, 47, 8, 46, 43, 46, 8, 39, 43, 8, 40, 39, 8, 30, 40, 8, 19, 30, 8, 3, 8, 1, 47, 1, 8, 44, 48, 46, 46, 48, 47, 1, 47, 48, 50, 1, 48, 50, 52, 1, 52, 54, 1, 0, 1, 54, 33, 0, 54, 56, 57, 23, 25, 23, 57, 32, 21, 58, 18, 58, 21, 59, 56, 29, 23, 29, 56, 60, 16, 61, 14, 61, 16, 62, 64, 63, 65, 63, 64, 59, 63, 56, 66, 56, 63, 67, 59, 27, 29, 27, 59, 45, 42, 49, 68, 49, 42, 65, 64, 69, 68, 69, 64, 55, 53, 67, 62, 67, 53, 60, 58, 16, 18, 16, 58, 61, 14, 57, 10, 57, 14, 42, 36, 68, 69, 68, 36, 70, 60, 66, 61, 66, 60, 65, 69, 70, 71, 70, 69, 53, 51, 62, 64, 62, 51, 38, 32, 71, 58, 71, 32, 70, 71, 60, 58, 60, 71, 63, 65, 66, 70, 66, 65, 51, 49, 64, 68, 64, 49, 55, 67, 34, 27, 34, 67, 67, 62, 59, 63, 59, 62, 36, 38, 69, 71, 69, 38, 66, 61, 56, 57, 56, 61, 57, 10, 25, 12, 25, 10]
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Scene"

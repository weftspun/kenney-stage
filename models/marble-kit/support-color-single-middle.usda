            texCoord2f[] primvars:st = [(0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375), (0.28125, 0.375)] (
